ARG BASE_IMAGE=registry.access.redhat.com/ubi9/ubi-minimal:9.7
ARG RELEASE_BASE_IMAGE=registry.access.redhat.com/ubi9/ubi-minimal:9.7
ARG OVMS_BRANCH=2026.2-release
ARG OV_BRANCH=releases/2026/2
ARG GENAI_BRANCH=releases/2026/2
ARG TOKENIZERS_BRANCH=releases/2026/2
ARG DRIVER_VERSION=25.05.32567
ARG LTO_CXX_FLAGS=-flto=auto -ffat-lto-objects -march=haswell
ARG LTO_LD_FLAGS=-flto=auto -ffat-lto-objects
ARG ov_use_binary=0

FROM ${BASE_IMAGE} as builder

RUN microdnf install -y python3 python3-devel gcc gcc-c++ cmake make git

WORKDIR /ovms
RUN git clone --branch ${OVMS_BRANCH} --depth 1 https://github.com/opendatahub-io/openvino_model_server.git .

FROM ${RELEASE_BASE_IMAGE}
COPY --from=builder /ovms/bin /ovms/bin
ENTRYPOINT ["/ovms/bin/ovms"]
